{
  "Version": "2012-10-17",
  "Id": "S3-Account-permissions",
  "Statement": [
    {
      "Sid": "1",
      "Effect": "Allow",
      "Principal": {
        "AWS": ["arn:aws:iam::123456:root"]
      },
      "Action": [
        "S3:GetObject",
        "S3:PutObject"
      ],
      "Resource": ["arn:aws:s3:::bucket/*"]
    }
  ]
}